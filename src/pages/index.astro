---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Six Seven</title>
		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html,
			body {
				height: 100%;
				overflow: hidden;
				touch-action: none;
			}

			body {
				background: #0d0d1a;
				color: #fff;
				font-family: system-ui, sans-serif;
				height: 100dvh;
				position: relative;
			}

			/* ── Screens ─────────────────────────────────────── */
			.screen {
				position: absolute;
				inset: 0;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 24px 16px env(safe-area-inset-bottom, 16px);
				gap: 16px;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.3s;
			}

			.screen.active {
				opacity: 1;
				pointer-events: auto;
			}

			/* ── Loading ─────────────────────────────────────── */
			.spinner {
				width: 44px;
				height: 44px;
				border: 3px solid #1e1e3f;
				border-top-color: #c084fc;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}

			@keyframes spin {
				to {
					transform: rotate(360deg);
				}
			}

			.status-text {
				font-size: 0.85rem;
				color: #6b7280;
				text-align: center;
			}

			/* ── Ready ───────────────────────────────────────── */
			.game-title {
				font-size: clamp(1.4rem, 6vw, 2.4rem);
				font-weight: 700;
				letter-spacing: 0.35em;
				color: #c084fc;
				text-transform: uppercase;
			}

			.btn-start {
				background: linear-gradient(135deg, #7c3aed, #c084fc);
				color: #fff;
				font-size: clamp(1.2rem, 5vw, 1.7rem);
				font-weight: 700;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				border: none;
				border-radius: 20px;
				padding: 18px 64px;
				cursor: pointer;
				box-shadow: 0 0 48px rgba(192, 132, 252, 0.35);
				transition:
					transform 0.1s,
					box-shadow 0.1s;
			}

			.btn-start:active {
				transform: scale(0.96);
				box-shadow: 0 0 20px rgba(192, 132, 252, 0.15);
			}

			.hint-ready {
				font-size: 0.78rem;
				color: #374151;
				text-align: center;
				max-width: 300px;
				line-height: 1.65;
			}

			.hint-ready strong {
				color: #9ca3af;
			}

			/* ── Countdown ───────────────────────────────────── */
			#countdown-number {
				font-size: clamp(7rem, 35vw, 20rem);
				font-weight: 900;
				line-height: 1;
				color: #fff;
			}

			#countdown-number.anim {
				animation: countPulse 0.9s ease-in-out forwards;
			}

			@keyframes countPulse {
				0% {
					transform: scale(1.5);
					opacity: 0;
				}
				25% {
					transform: scale(1);
					opacity: 1;
				}
				75% {
					transform: scale(1);
					opacity: 1;
				}
				100% {
					transform: scale(0.7);
					opacity: 0;
				}
			}

			/* ── Game ────────────────────────────────────────── */
			#screen-game {
				justify-content: flex-start;
				padding-top: 10px;
				gap: 6px;
			}

			.hud {
				display: flex;
				width: 100%;
				max-width: min(100vw - 32px, 720px);
				justify-content: space-between;
				align-items: flex-end;
				flex-shrink: 0;
			}

			.hud-block {
				line-height: 1;
				text-align: center;
				min-width: 80px;
			}

			.hud-label {
				font-size: 0.65rem;
				letter-spacing: 0.18em;
				color: #6b7280;
				text-transform: uppercase;
				margin-bottom: 2px;
			}

			.hud-value {
				font-size: clamp(2.2rem, 11vw, 5.5rem);
				font-weight: 900;
				line-height: 1;
			}

			#timer-value {
				color: #f9a8d4;
				transition: color 0.3s;
			}

			#timer-value.urgent {
				color: #f87171;
				animation: blink 0.5s step-end infinite;
			}

			@keyframes blink {
				50% {
					opacity: 0.35;
				}
			}

			#score-value {
				color: #fff;
				transition:
					color 0.15s,
					transform 0.15s;
				display: inline-block;
			}

			#score-value.pop {
				color: #4ade80;
				transform: scale(1.25);
			}

			#canvas-wrap {
				border-radius: 16px;
				border: 2px solid #1e1e3f;
				box-shadow: 0 0 48px rgba(168, 85, 247, 0.12);
				flex: 1 1 0;
				min-height: 0;
				width: 100%;
				max-width: min(100vw - 32px, 720px);
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}

			#canvas {
				display: block;
				max-width: 100%;
				max-height: 100%;
				width: auto;
				height: auto;
			}

			.hint-game {
				font-size: 0.65rem;
				color: #374151;
				text-align: center;
				flex-shrink: 0;
			}

			/* ── Result ──────────────────────────────────────── */
			.result-label {
				font-size: 0.8rem;
				letter-spacing: 0.22em;
				color: #6b7280;
				text-transform: uppercase;
			}

			.result-score {
				font-size: clamp(6rem, 30vw, 14rem);
				font-weight: 900;
				line-height: 1;
				color: #4ade80;
			}

			.result-sub {
				font-size: 0.85rem;
				color: #4b5563;
			}

			.btn-again {
				background: transparent;
				color: #c084fc;
				font-size: 1rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				border: 2px solid #7c3aed;
				border-radius: 14px;
				padding: 12px 40px;
				cursor: pointer;
				margin-top: 8px;
				transition: background 0.15s;
			}

			.btn-again:active {
				background: #1e1e3f;
			}
		</style>
	</head>
	<body>
		<!-- Loading screen -->
		<div id="screen-loading" class="screen active">
			<div class="spinner"></div>
			<p id="status" class="status-text">Initialising…</p>
		</div>

		<!-- Ready screen -->
		<div id="screen-ready" class="screen">
			<p class="game-title">Six Seven</p>
			<button id="btn-start" class="btn-start">Start</button>
			<p class="hint-ready">
				Show <strong>both hands</strong> · one hand <strong>↑ up</strong
				>, other <strong>↓ down</strong> = +1 point · 60 seconds
			</p>
			<p>
				<strong>v0.0.2</strong>
			</p>
		</div>

		<!-- Countdown screen -->
		<div id="screen-countdown" class="screen">
			<span id="countdown-number">3</span>
		</div>

		<!-- Game screen -->
		<div id="screen-game" class="screen">
			<div class="hud">
				<div class="hud-block">
					<p class="hud-label">Time</p>
					<span id="timer-value" class="hud-value">60</span>
				</div>
				<div class="hud-block">
					<p class="hud-label">Score</p>
					<span id="score-value" class="hud-value">0</span>
				</div>
			</div>

			<div id="canvas-wrap">
				<canvas id="canvas" width="640" height="480"></canvas>
			</div>

			<p class="hint-game">↑↓ opposite hands simultaneously = +1 point</p>
		</div>

		<!-- Result screen -->
		<div id="screen-result" class="screen">
			<p class="result-label">Your Score</p>
			<p id="result-score" class="result-score">0</p>
			<p class="result-sub">in 60 seconds</p>
			<button id="btn-again" class="btn-again">Play Again</button>
		</div>

		<video id="video" autoplay playsinline muted style="display:none"
		></video>

		<script>
			import {
				HandLandmarker,
				FilesetResolver,
			} from "@mediapipe/tasks-vision";

			/* ── DOM refs ──────────────────────────────────────── */
			const video = document.getElementById("video") as HTMLVideoElement;
			const canvas = document.getElementById(
				"canvas",
			) as HTMLCanvasElement;
			const scoreEl = document.getElementById(
				"score-value",
			) as HTMLElement;
			const timerEl = document.getElementById(
				"timer-value",
			) as HTMLElement;
			const statusEl = document.getElementById("status") as HTMLElement;
			const resultScoreEl = document.getElementById(
				"result-score",
			) as HTMLElement;
			const countdownEl = document.getElementById(
				"countdown-number",
			) as HTMLElement;
			const ctx = canvas.getContext("2d")!;

			/* ── Screen helper ─────────────────────────────────── */
			function showScreen(id: string) {
				document
					.querySelectorAll<HTMLElement>(".screen")
					.forEach((s) => {
						s.classList.toggle("active", s.id === id);
					});
			}

			/* ── MediaPipe assets ──────────────────────────────── */
			const WASM_CDN =
				"https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.35/wasm";
			const MODEL_URL =
				"https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/1/hand_landmarker.task";

			/* ── Hand skeleton connections ─────────────────────── */
			const CONNECTIONS: [number, number][] = [
				[0, 1],
				[1, 2],
				[2, 3],
				[3, 4],
				[0, 5],
				[5, 6],
				[6, 7],
				[7, 8],
				[5, 9],
				[9, 10],
				[10, 11],
				[11, 12],
				[9, 13],
				[13, 14],
				[14, 15],
				[15, 16],
				[13, 17],
				[17, 18],
				[18, 19],
				[19, 20],
				[0, 17],
			];

			/* ── Config ────────────────────────────────────────── */
			/** Fewer frames = faster direction detection for quick moves */
			const HISTORY = 5;
			const THRESHOLD = 0.025;
			const GAME_DURATION = 60;
			/** Score if both opposite directions happened within this window (ms) */
			const DIR_WINDOW_MS = 450;

			/* ── State ─────────────────────────────────────────── */
			type Dir = "up" | "down" | "neutral";
			interface HandState {
				yHistory: number[];
				dir: Dir;
				lastUp: number; // performance.now() of last "up" frame
				lastDown: number; // performance.now() of last "down" frame
			}

			let hands: Record<string, HandState> = {};
			let score = 0;
			let cycleUsed = false;
			let lastVidTime = -1;
			let hl: HandLandmarker;
			let rafId = 0;
			let gameStream: MediaStream | null = null;
			let timeLeft = GAME_DURATION;
			let timerInterval: ReturnType<typeof setInterval> | null = null;
			let gameActive = false;

			/* ── Tracking ──────────────────────────────────────── */
			function trackHand(id: string, y: number, now: number) {
				if (!hands[id])
					hands[id] = {
						yHistory: [],
						dir: "neutral",
						lastUp: 0,
						lastDown: 0,
					};
				const h = hands[id];
				h.yHistory.push(y);
				if (h.yHistory.length > HISTORY) h.yHistory.shift();
				if (h.yHistory.length < 2) return;
				const n = h.yHistory.length;
				// Compare newest vs oldest in the short buffer
				const delta = h.yHistory[n - 1] - h.yHistory[0];
				h.dir =
					delta < -THRESHOLD
						? "up"
						: delta > THRESHOLD
							? "down"
							: "neutral";
				if (h.dir === "up") h.lastUp = now;
				if (h.dir === "down") h.lastDown = now;
			}

			/* ── Drawing ───────────────────────────────────────── */
			function drawHand(
				lms: { x: number; y: number }[],
				dir: Dir,
				cw: number,
				ch: number,
			) {
				const color =
					dir === "up"
						? "#4ade80"
						: dir === "down"
							? "#f87171"
							: "#a78bfa";
				ctx.save();
				ctx.strokeStyle = color;
				ctx.lineWidth = 3;
				ctx.lineCap = "round";
				ctx.lineJoin = "round";
				for (const [a, b] of CONNECTIONS) {
					ctx.beginPath();
					ctx.moveTo((1 - lms[a].x) * cw, lms[a].y * ch);
					ctx.lineTo((1 - lms[b].x) * cw, lms[b].y * ch);
					ctx.stroke();
				}
				ctx.fillStyle = "#ffffff";
				for (const lm of lms) {
					ctx.beginPath();
					ctx.arc((1 - lm.x) * cw, lm.y * ch, 4, 0, Math.PI * 2);
					ctx.fill();
				}
				const wx = (1 - lms[0].x) * cw;
				const wy = lms[0].y * ch;
				ctx.font = "bold 34px sans-serif";
				ctx.textAlign = "center";
				ctx.textBaseline = "bottom";
				ctx.fillStyle = color;
				ctx.fillText(
					dir === "up" ? "↑" : dir === "down" ? "↓" : "·",
					wx,
					wy - 6,
				);
				ctx.restore();
			}

			/* ── Game loop ─────────────────────────────────────── */
			function loop() {
				if (!gameActive) return;
				if (
					video.currentTime !== lastVidTime &&
					video.readyState >= 2
				) {
					lastVidTime = video.currentTime;
					const cw = canvas.width;
					const ch = canvas.height;
					ctx.save();
					ctx.scale(-1, 1);
					ctx.drawImage(video, -cw, 0, cw, ch);
					ctx.restore();
					const res = hl.detectForVideo(video, performance.now());
					const seen = new Set<string>();
					for (let i = 0; i < (res.landmarks?.length ?? 0); i++) {
						const lms = res.landmarks[i];
						const id =
							res.handedness[i]?.[0]?.categoryName ?? `h${i}`;
						seen.add(id);
						trackHand(id, lms[0].y, performance.now());
						drawHand(lms, hands[id].dir, cw, ch);
					}
					for (const id of Object.keys(hands)) {
						if (!seen.has(id)) delete hands[id];
					}
					const ids = Object.keys(hands);
					if (ids.length >= 2) {
						const now = performance.now();
						const h0 = hands[ids[0]];
						const h1 = hands[ids[1]];
						// Score if both opposite directions happened within the window
						const h0up = now - h0.lastUp < DIR_WINDOW_MS;
						const h0down = now - h0.lastDown < DIR_WINDOW_MS;
						const h1up = now - h1.lastUp < DIR_WINDOW_MS;
						const h1down = now - h1.lastDown < DIR_WINDOW_MS;
						const opposite = (h0up && h1down) || (h0down && h1up);
						// Reset once current real-time dirs are no longer opposite
						const currentOpposite =
							(h0.dir === "up" && h1.dir === "down") ||
							(h0.dir === "down" && h1.dir === "up");
						if (opposite && !cycleUsed) {
							score++;
							scoreEl.textContent = String(score);
							scoreEl.classList.add("pop");
							setTimeout(
								() => scoreEl.classList.remove("pop"),
								300,
							);
							cycleUsed = true;
						}
						if (!currentOpposite) cycleUsed = false;
					} else {
						cycleUsed = false;
					}
				}
				rafId = requestAnimationFrame(loop);
			}

			/* ── End game ──────────────────────────────────────── */
			function endGame() {
				gameActive = false;
				cancelAnimationFrame(rafId);
				if (timerInterval) {
					clearInterval(timerInterval);
					timerInterval = null;
				}
				if (gameStream) {
					gameStream.getTracks().forEach((t) => t.stop());
					gameStream = null;
					video.srcObject = null;
				}
				resultScoreEl.textContent = String(score);
				showScreen("screen-result");
			}

			/* ── Start game (called after countdown) ───────────── */
			async function startGame(stream: MediaStream) {
				// Reset state
				score = 0;
				cycleUsed = false;
				lastVidTime = -1;
				hands = {};
				timeLeft = GAME_DURATION;
				scoreEl.textContent = "0";
				timerEl.textContent = String(GAME_DURATION);
				timerEl.classList.remove("urgent");

				gameStream = stream;
				video.srcObject = stream;
				await new Promise<void>((resolve) => {
					video.addEventListener("loadedmetadata", () => resolve(), {
						once: true,
					});
				});
				await video.play();
				canvas.width = video.videoWidth || 640;
				canvas.height = video.videoHeight || 480;

				showScreen("screen-game");
				gameActive = true;

				timerInterval = setInterval(() => {
					timeLeft--;
					timerEl.textContent = String(timeLeft);
					if (timeLeft <= 10) timerEl.classList.add("urgent");
					if (timeLeft <= 0) endGame();
				}, 1000);

				rafId = requestAnimationFrame(loop);
			}

			/* ── Animated countdown 3 → 2 → 1 ─────────────────── */
			function runCountdown(): Promise<void> {
				showScreen("screen-countdown");
				return new Promise((resolve) => {
					const nums = [3, 2, 1];
					let i = 0;
					function tick() {
						if (i >= nums.length) {
							setTimeout(resolve, 150);
							return;
						}
						countdownEl.textContent = String(nums[i]);
						// Restart CSS animation
						countdownEl.classList.remove("anim");
						void countdownEl.offsetWidth;
						countdownEl.classList.add("anim");
						i++;
						setTimeout(tick, 900);
					}
					tick();
				});
			}

			/* ── Request camera ────────────────────────────────── */
			async function requestCamera(): Promise<MediaStream> {
				if (!navigator.mediaDevices?.getUserMedia) {
					throw new Error(
						"Camera API unavailable. This page must be served over HTTPS (or localhost).",
					);
				}
				return navigator.mediaDevices.getUserMedia({
					video: {
						facingMode: "user",
						width: { ideal: 1280 },
						height: { ideal: 720 },
					},
				});
			}

			/* ── Button: Start ─────────────────────────────────── */
			document
				.getElementById("btn-start")!
				.addEventListener("click", async () => {
					try {
						// Kick off camera request and countdown in parallel
						const [stream] = await Promise.all([
							requestCamera(),
							runCountdown(),
						]);
						await startGame(stream);
					} catch (err) {
						statusEl.textContent = `Error: ${(err as Error).message ?? err}`;
						showScreen("screen-loading");
						console.error(err);
					}
				});

			/* ── Button: Play Again ────────────────────────────── */
			document
				.getElementById("btn-again")!
				.addEventListener("click", () => {
					showScreen("screen-ready");
				});

			/* ── Init: load model only ─────────────────────────── */
			async function main() {
				statusEl.textContent = "Loading WASM…";
				const fs = await FilesetResolver.forVisionTasks(WASM_CDN);
				statusEl.textContent = "Loading model…";
				try {
					hl = await HandLandmarker.createFromOptions(fs, {
						baseOptions: {
							modelAssetPath: MODEL_URL,
							delegate: "GPU",
						},
						runningMode: "VIDEO",
						numHands: 2,
					});
				} catch {
					hl = await HandLandmarker.createFromOptions(fs, {
						baseOptions: {
							modelAssetPath: MODEL_URL,
							delegate: "CPU",
						},
						runningMode: "VIDEO",
						numHands: 2,
					});
				}
				showScreen("screen-ready");
			}

			main().catch((err) => {
				statusEl.textContent = `Error: ${(err as Error).message ?? err}`;
				console.error(err);
			});
		</script>
	</body>
</html>
