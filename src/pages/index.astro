<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Six Seven</title>
		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html,
			body {
				height: 100%;
				overflow: hidden;
				touch-action: none;
			}

			body {
				background: #0d0d1a;
				color: #fff;
				font-family: system-ui, sans-serif;
				height: 100dvh;
				position: relative;
			}

			/* ── Screens ─────────────────────────────────────── */
			.screen {
				position: absolute;
				inset: 0;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 24px 16px env(safe-area-inset-bottom, 16px);
				gap: 16px;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.3s;
			}

			.screen.active {
				opacity: 1;
				pointer-events: auto;
			}

			/* ── Loading ─────────────────────────────────────── */
			.spinner {
				width: 44px;
				height: 44px;
				border: 3px solid #1e1e3f;
				border-top-color: #c084fc;
				border-radius: 50%;
				animation: spin 0.8s linear infinite;
			}

			@keyframes spin {
				to {
					transform: rotate(360deg);
				}
			}

			.status-text {
				font-size: 0.85rem;
				color: #6b7280;
				text-align: center;
			}

			/* ── Ready ───────────────────────────────────────── */
			.game-title {
				font-size: clamp(1.4rem, 6vw, 2.4rem);
				font-weight: 700;
				letter-spacing: 0.35em;
				color: #c084fc;
				text-transform: uppercase;
			}

			.btn-start {
				background: linear-gradient(135deg, #7c3aed, #c084fc);
				color: #fff;
				font-size: clamp(1.2rem, 5vw, 1.7rem);
				font-weight: 700;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				border: none;
				border-radius: 20px;
				padding: 18px 64px;
				cursor: pointer;
				box-shadow: 0 0 48px rgba(192, 132, 252, 0.35);
				transition:
					transform 0.1s,
					box-shadow 0.1s;
			}

			.btn-start:active {
				transform: scale(0.96);
				box-shadow: 0 0 20px rgba(192, 132, 252, 0.15);
			}

			.hint-ready {
				font-size: 0.78rem;
				color: #374151;
				text-align: center;
				max-width: 300px;
				line-height: 1.65;
			}

			.hint-ready strong {
				color: #9ca3af;
			}

			/* ── Countdown ───────────────────────────────────── */
			#countdown-number {
				font-size: clamp(7rem, 35vw, 20rem);
				font-weight: 900;
				line-height: 1;
				color: #fff;
			}

			#countdown-number.anim {
				animation: countPulse 0.9s ease-in-out forwards;
			}

			@keyframes countPulse {
				0% {
					transform: scale(1.5);
					opacity: 0;
				}
				25% {
					transform: scale(1);
					opacity: 1;
				}
				75% {
					transform: scale(1);
					opacity: 1;
				}
				100% {
					transform: scale(0.7);
					opacity: 0;
				}
			}

			/* ── Game ────────────────────────────────────────── */
			#screen-game {
				justify-content: flex-start;
				padding-top: 10px;
				gap: 6px;
			}

			.hud {
				display: flex;
				width: 100%;
				max-width: min(100vw - 32px, 720px);
				justify-content: space-between;
				align-items: flex-end;
				flex-shrink: 0;
			}

			.hud-block {
				line-height: 1;
				text-align: center;
				min-width: 80px;
			}

			.hud-label {
				font-size: 0.65rem;
				letter-spacing: 0.18em;
				color: #6b7280;
				text-transform: uppercase;
				margin-bottom: 2px;
			}

			.hud-value {
				font-size: clamp(2.2rem, 11vw, 5.5rem);
				font-weight: 900;
				line-height: 1;
			}

			#timer-value {
				color: #f9a8d4;
				transition: color 0.3s;
			}

			#timer-value.urgent {
				color: #f87171;
				animation: blink 0.5s step-end infinite;
			}

			@keyframes blink {
				50% {
					opacity: 0.35;
				}
			}

			#score-value {
				color: #fff;
				transition:
					color 0.15s,
					transform 0.15s;
				display: inline-block;
			}

			#score-value.pop {
				color: #4ade80;
				transform: scale(1.25);
			}

			#canvas-wrap {
				border-radius: 16px;
				border: 2px solid #1e1e3f;
				box-shadow: 0 0 48px rgba(168, 85, 247, 0.12);
				flex: 1 1 0;
				min-height: 0;
				width: 100%;
				max-width: min(100vw - 32px, 720px);
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}

			#canvas {
				display: block;
				max-width: 100%;
				max-height: 100%;
				width: auto;
				height: auto;
			}

			.hint-game {
				font-size: 0.65rem;
				color: #374151;
				text-align: center;
				flex-shrink: 0;
			}

			/* ── Result ──────────────────────────────────────── */
			.result-label {
				font-size: 0.8rem;
				letter-spacing: 0.22em;
				color: #6b7280;
				text-transform: uppercase;
			}

			.result-score {
				font-size: clamp(6rem, 30vw, 14rem);
				font-weight: 900;
				line-height: 1;
				color: #4ade80;
			}

			.result-sub {
				font-size: 0.85rem;
				color: #4b5563;
			}

			.btn-again {
				background: transparent;
				color: #c084fc;
				font-size: 1rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				border: 2px solid #7c3aed;
				border-radius: 14px;
				padding: 12px 40px;
				cursor: pointer;
				margin-top: 8px;
				transition: background 0.15s;
			}

			.btn-again:active {
				background: #1e1e3f;
			}
		</style>
	</head>
	<body>
		<!-- Loading screen -->
		<div id="screen-loading" class="screen active">
			<div class="spinner"></div>
			<p id="status" class="status-text">Initialising…</p>
		</div>

		<!-- Ready screen -->
		<div id="screen-ready" class="screen">
			<p class="game-title">Six Seven</p>
			<button id="btn-start" class="btn-start">Start</button>
			<p class="hint-ready">
				Angkat <strong>tangan ↑ naik</strong>, turunkan yang lain
				<strong>↓ turun</strong> = +1 point
			</p>
			<p>
				<strong>v0.0.13</strong>
			</p>
		</div>

		<!-- Countdown screen -->
		<div id="screen-countdown" class="screen">
			<span id="countdown-number">3</span>
		</div>

		<!-- Game screen -->
		<div id="screen-game" class="screen">
			<div class="hud">
				<div class="hud-block">
					<p class="hud-label">Waktu</p>
					<span id="timer-value" class="hud-value">60</span>
				</div>
				<div class="hud-block">
					<p class="hud-label">Score</p>
					<span id="score-value" class="hud-value">0</span>
				</div>
			</div>

			<div id="canvas-wrap">
				<canvas id="canvas" width="640" height="480"></canvas>
			</div>

			<p class="hint-game">
				↑↓ tangan berlawanan secara bersamaan = +1 point
			</p>
		</div>

		<!-- Result screen -->
		<div id="screen-result" class="screen">
			<p class="result-label">Score Anda</p>
			<p id="result-score" class="result-score">0</p>
			<p class="result-sub">dalam 20 detik</p>
			<button id="btn-again" class="btn-again">Main Lagi</button>
		</div>

		<video id="video" autoplay playsinline muted style="display:none"
		></video>

		<script>
			import {
				PoseLandmarker,
				FilesetResolver,
			} from "@mediapipe/tasks-vision";

			/* ── DOM refs ──────────────────────────────────────── */
			const video = document.getElementById("video") as HTMLVideoElement;
			const canvas = document.getElementById(
				"canvas",
			) as HTMLCanvasElement;
			const scoreEl = document.getElementById(
				"score-value",
			) as HTMLElement;
			const timerEl = document.getElementById(
				"timer-value",
			) as HTMLElement;
			const statusEl = document.getElementById("status") as HTMLElement;
			const resultScoreEl = document.getElementById(
				"result-score",
			) as HTMLElement;
			const countdownEl = document.getElementById(
				"countdown-number",
			) as HTMLElement;
			const ctx = canvas.getContext("2d")!;

			/* ── Screen helper ─────────────────────────────────── */
			function showScreen(id: string) {
				document
					.querySelectorAll<HTMLElement>(".screen")
					.forEach((s) => {
						s.classList.toggle("active", s.id === id);
					});
			}

			/* ── MediaPipe assets ──────────────────────────────── */
			const WASM_CDN =
				"https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.35/wasm";
			const MODEL_URL =
				"https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_lite/float16/1/pose_landmarker_lite.task";

			/* ── Pose skeleton connections (subset) ────────────── */
			const CONNECTIONS: [number, number][] = [
				// torso
				[11, 12],
				[11, 23],
				[12, 24],
				[23, 24],
				// left arm
				[11, 13],
				[13, 15],
				// right arm
				[12, 14],
				[14, 16],
				// left leg
				[23, 25],
				[25, 27],
				// right leg
				[24, 26],
				[26, 28],
			];
			/** Pose landmark indices for left & right wrists */
			const WRIST_IDS = ["left", "right"] as const;
			const WRIST_IDX = { left: 15, right: 16 } as const;

			/* ── Config ────────────────────────────────────────── */
			/** Fewer frames = faster direction detection for quick moves */
			const HISTORY = 3;
			const THRESHOLD = 0.02;
			const GAME_DURATION = 20;
			/** Score if both opposite directions happened within this window (ms) */
			const DIR_WINDOW_MS = 400;
			/** Keep hand state alive this long after last detection (handles missed frames) */
			const HAND_GRACE_MS = 300;
			/** Minimum ms between consecutive scores (prevents double-counting) */
			const SCORE_COOLDOWN_MS = 180;

			/* ── State ─────────────────────────────────────────── */
			type Dir = "up" | "down" | "neutral";
			interface HandState {
				yHistory: number[];
				dir: Dir;
				lastUp: number; // performance.now() of last "up" frame
				lastDown: number; // performance.now() of last "down" frame
				lastSeen: number; // performance.now() of last detected frame
			}

			let hands: Record<string, HandState> = {};
			let score = 0;
			let lastScoreTime = 0;
			let lastVidTime = -1;
			let pl: PoseLandmarker;
			let rafId = 0;
			let gameStream: MediaStream | null = null;
			let timeLeft = GAME_DURATION;
			let timerInterval: ReturnType<typeof setInterval> | null = null;
			let gameActive = false;

			/* ── Tracking ──────────────────────────────────────── */
			function trackHand(id: string, y: number, now: number) {
				if (!hands[id])
					hands[id] = {
						yHistory: [],
						dir: "neutral",
						lastUp: 0,
						lastDown: 0,
						lastSeen: now,
					};
				hands[id].lastSeen = now;
				const h = hands[id];
				h.yHistory.push(y);
				if (h.yHistory.length > HISTORY) h.yHistory.shift();
				if (h.yHistory.length < 2) return;
				const n = h.yHistory.length;
				// Instantaneous velocity (last 2 frames) catches fast flicks
				const instant = h.yHistory[n - 1] - h.yHistory[n - 2];
				// Short-term trend normalised to per-frame magnitude
				const trend = (h.yHistory[n - 1] - h.yHistory[0]) / (n - 1);
				// Use whichever signal is stronger
				const delta =
					Math.abs(instant) >= Math.abs(trend) ? instant : trend;
				h.dir =
					delta < -THRESHOLD
						? "up"
						: delta > THRESHOLD
							? "down"
							: "neutral";
				if (h.dir === "up") h.lastUp = now;
				if (h.dir === "down") h.lastDown = now;
			}

			/* ── Drawing ───────────────────────────────────────── */
			function drawPose(
				lms: { x: number; y: number; visibility?: number }[],
				wristDirs: Record<string, Dir>,
				cw: number,
				ch: number,
			) {
				ctx.save();
				// Draw skeleton
				ctx.strokeStyle = "#a78bfa";
				ctx.lineWidth = 3;
				ctx.lineCap = "round";
				ctx.lineJoin = "round";
				for (const [a, b] of CONNECTIONS) {
					if (
						(lms[a]?.visibility ?? 1) < 0.3 ||
						(lms[b]?.visibility ?? 1) < 0.3
					)
						continue;
					ctx.beginPath();
					ctx.moveTo((1 - lms[a].x) * cw, lms[a].y * ch);
					ctx.lineTo((1 - lms[b].x) * cw, lms[b].y * ch);
					ctx.stroke();
				}
				// Draw joints
				ctx.fillStyle = "#ffffff";
				for (const [a, b] of CONNECTIONS) {
					for (const idx of [a, b]) {
						if ((lms[idx]?.visibility ?? 1) < 0.3) continue;
						ctx.beginPath();
						ctx.arc(
							(1 - lms[idx].x) * cw,
							lms[idx].y * ch,
							4,
							0,
							Math.PI * 2,
						);
						ctx.fill();
					}
				}
				// Draw direction arrows on wrists
				for (const side of WRIST_IDS) {
					const idx = WRIST_IDX[side];
					const lm = lms[idx];
					if (!lm || (lm.visibility ?? 1) < 0.3) continue;
					const dir = wristDirs[side] ?? "neutral";
					const color =
						dir === "up"
							? "#4ade80"
							: dir === "down"
								? "#f87171"
								: "#a78bfa";
					const wx = (1 - lm.x) * cw;
					const wy = lm.y * ch;
					ctx.font = "bold 34px sans-serif";
					ctx.textAlign = "center";
					ctx.textBaseline = "bottom";
					ctx.fillStyle = color;
					ctx.fillText(
						dir === "up" ? "↑" : dir === "down" ? "↓" : "·",
						wx,
						wy - 6,
					);
				}
				ctx.restore();
			}

			/* ── Game loop ─────────────────────────────────────── */
			function loop() {
				if (!gameActive) return;
				if (
					video.currentTime !== lastVidTime &&
					video.readyState >= 2
				) {
					lastVidTime = video.currentTime;
					const cw = canvas.width;
					const ch = canvas.height;
					ctx.save();
					ctx.scale(-1, 1);
					ctx.drawImage(video, -cw, 0, cw, ch);
					ctx.restore();
					const res = pl.detectForVideo(video, performance.now());
					const now2 = performance.now();
					const lms = res.landmarks?.[0];
					const seenSides = new Set<string>();
					if (lms) {
						for (const side of WRIST_IDS) {
							const idx = WRIST_IDX[side];
							const lm = lms[idx];
							if (lm && (lm.visibility ?? 1) >= 0.3) {
								seenSides.add(side);
								trackHand(side, lm.y, now2);
							}
						}
						const wristDirs: Record<string, Dir> = {};
						for (const side of WRIST_IDS)
							wristDirs[side] = hands[side]?.dir ?? "neutral";
						drawPose(lms, wristDirs, cw, ch);
					}
					for (const id of Object.keys(hands)) {
						if (
							!seenSides.has(id) &&
							now2 - hands[id].lastSeen > HAND_GRACE_MS
						)
							delete hands[id];
					}
					const ids = Object.keys(hands);
					if (ids.length >= 2) {
						const now = performance.now();
						const h0 = hands[ids[0]];
						const h1 = hands[ids[1]];
						// Score if both opposite directions happened within the window
						const h0up = now - h0.lastUp < DIR_WINDOW_MS;
						const h0down = now - h0.lastDown < DIR_WINDOW_MS;
						const h1up = now - h1.lastUp < DIR_WINDOW_MS;
						const h1down = now - h1.lastDown < DIR_WINDOW_MS;
						const opposite = (h0up && h1down) || (h0down && h1up);
						if (
							opposite &&
							now - lastScoreTime > SCORE_COOLDOWN_MS
						) {
							score++;
							lastScoreTime = now;
							scoreEl.textContent = String(score);
							scoreEl.classList.add("pop");
							setTimeout(
								() => scoreEl.classList.remove("pop"),
								300,
							);
						}
					}
				}
				rafId = requestAnimationFrame(loop);
			}

			/* ── End game ──────────────────────────────────────── */
			function endGame() {
				gameActive = false;
				cancelAnimationFrame(rafId);
				if (timerInterval) {
					clearInterval(timerInterval);
					timerInterval = null;
				}
				if (gameStream) {
					gameStream.getTracks().forEach((t) => t.stop());
					gameStream = null;
					video.srcObject = null;
				}
				resultScoreEl.textContent = String(score);
				showScreen("screen-result");
			}

			/* ── Start game (called after countdown) ───────────── */
			async function startGame(stream: MediaStream) {
				// Reset state
				score = 0;
				lastScoreTime = 0;
				lastVidTime = -1;
				hands = {};
				timeLeft = GAME_DURATION;
				scoreEl.textContent = "0";
				timerEl.textContent = String(GAME_DURATION);
				timerEl.classList.remove("urgent");

				gameStream = stream;
				video.srcObject = stream;
				await new Promise<void>((resolve) => {
					video.addEventListener("loadedmetadata", () => resolve(), {
						once: true,
					});
				});
				await video.play();
				canvas.width = video.videoWidth || 640;
				canvas.height = video.videoHeight || 480;

				showScreen("screen-game");
				gameActive = true;

				timerInterval = setInterval(() => {
					timeLeft--;
					timerEl.textContent = String(timeLeft);
					if (timeLeft <= 10) timerEl.classList.add("urgent");
					if (timeLeft <= 0) endGame();
				}, 1000);

				rafId = requestAnimationFrame(loop);
			}

			/* ── Animated countdown 3 → 2 → 1 ─────────────────── */
			function runCountdown(): Promise<void> {
				showScreen("screen-countdown");
				return new Promise((resolve) => {
					const nums = [3, 2, 1];
					let i = 0;
					function tick() {
						if (i >= nums.length) {
							setTimeout(resolve, 150);
							return;
						}
						countdownEl.textContent = String(nums[i]);
						// Restart CSS animation
						countdownEl.classList.remove("anim");
						void countdownEl.offsetWidth;
						countdownEl.classList.add("anim");
						i++;
						setTimeout(tick, 900);
					}
					tick();
				});
			}

			/* ── Request camera ────────────────────────────────── */
			async function requestCamera(): Promise<MediaStream> {
				if (!navigator.mediaDevices?.getUserMedia) {
					throw new Error(
						"Camera API unavailable. This page must be served over HTTPS (or localhost).",
					);
				}
				return navigator.mediaDevices.getUserMedia({
					video: {
						facingMode: "user",
						width: { ideal: 1280 },
						height: { ideal: 720 },
					},
				});
			}

			/* ── Button: Start ─────────────────────────────────── */
			document
				.getElementById("btn-start")!
				.addEventListener("click", async () => {
					try {
						// Kick off camera request and countdown in parallel
						const [stream] = await Promise.all([
							requestCamera(),
							runCountdown(),
						]);
						await startGame(stream);
					} catch (err) {
						statusEl.textContent = `Error: ${(err as Error).message ?? err}`;
						showScreen("screen-loading");
						console.error(err);
					}
				});

			/* ── Button: Play Again ────────────────────────────── */
			document
				.getElementById("btn-again")!
				.addEventListener("click", () => {
					showScreen("screen-ready");
				});

			/* ── Init: load model only ─────────────────────────── */
			async function main() {
				statusEl.textContent = "Loading WASM…";
				const fs = await FilesetResolver.forVisionTasks(WASM_CDN);
				statusEl.textContent = "Loading model…";
				try {
					pl = await PoseLandmarker.createFromOptions(fs, {
						baseOptions: {
							modelAssetPath: MODEL_URL,
							delegate: "GPU",
						},
						runningMode: "VIDEO",
						numPoses: 1,
						minPoseDetectionConfidence: 0.3,
						minPosePresenceConfidence: 0.3,
						minTrackingConfidence: 0.3,
					});
				} catch {
					pl = await PoseLandmarker.createFromOptions(fs, {
						baseOptions: {
							modelAssetPath: MODEL_URL,
							delegate: "CPU",
						},
						runningMode: "VIDEO",
						numPoses: 1,
						minPoseDetectionConfidence: 0.3,
						minPosePresenceConfidence: 0.3,
						minTrackingConfidence: 0.3,
					});
				}
				showScreen("screen-ready");
			}

			main().catch((err) => {
				statusEl.textContent = `Error: ${(err as Error).message ?? err}`;
				console.error(err);
			});
		</script>
	</body>
</html>
